{
  "name": "japanese-study-app",
  "version": "0.1.0",
  "description": "Electron Japanese study app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.nihongo.study",
    "productName": "NihonGo Study",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "yaml": "^2.9.0"
  }
}
