{
  "name": "japanese-study-app",
  "version": "0.1.0",
  "private": true,
  "description": "Electron Japanese study app",
  "main": "apps/desktop/src/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "electron .",
    "build": "node apps/desktop/scripts/build-windows.js"
  },
  "build": {
    "appId": "com.nihongo.study",
    "productName": "NihonGo Study",
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/desktop/src/**/*",
      "apps/desktop/package.json",
      "packages/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    }
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "yaml": "^2.9.0"
  }
}
