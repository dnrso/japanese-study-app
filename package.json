{
  "name": "japanese-study-app",
  "version": "0.1.0",
  "private": true,
  "description": "Electron Japanese study app",
  "main": "apps/desktop/src/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "electron .",
    "build": "node apps/desktop/scripts/build-windows.js",
    "web:dev": "npm --workspace @nihongo-study/web run dev --",
    "web:build": "npm run build --workspace @nihongo-study/web",
    "web:preview": "npm --workspace @nihongo-study/web run preview --",
    "android:sync": "npm run web:build && npm --workspace @nihongo-study/web run cap:sync",
    "android:open": "npm --workspace @nihongo-study/web run cap:open",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.nihongo.study",
    "productName": "NihonGo Study",
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/desktop/src/**/*",
      "apps/desktop/package.json",
      "packages/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    }
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "fake-indexeddb": "^6.2.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "yaml": "^2.9.0"
  }
}
